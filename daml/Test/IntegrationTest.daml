module Test.IntegrationTest where

import Daml.Script
import DA.Date (date, Month(..))
import DA.Optional (isSome)

import Identity.Types
import Identity.Roles
import Civil.BirthCertificate qualified as BC
import Civil.BirthCertificate (BirthRegistrationRequest(..), BirthInfo(..), Sex(..))
import Passport.Types
import Passport.Passport qualified as PP
import Passport.Passport (IdentityRequest(..))
import Voting.Voting qualified as V
import Voting.Voting (VoterRegistrationRequest(..), VoterInfo(..), Election(..), ElectionStatus(..), CastBallot(..))
import AML.Compliance
import Content.ContentAuth qualified as CC
import Content.ContentAuth (ContentRegistrationRequest(..), ContentInfo(..), ContentType(..))

-- | Test 1: Birth cert → passport — foundational identity chain
--
-- PRIVACY GUARANTEE:
--   Verifies that identity data flows across modules only through explicit
--   holder action, not through shared state. Alice's BirthCertificate and
--   DigitalPassport are separate contracts with separate stakeholder sets.
--   The birth registry is not an observer on the passport; the passport
--   authority is not an observer on the birth certificate. The holder
--   (Alice) is the only party present in both contracts, and she manually
--   copies her identity fields from birth info to passport info when
--   submitting the IdentityRequest. There is no automatic cross-module
--   data link that would give one authority access to the other's records.
--
-- REGULATORY SIGNIFICANCE:
--   Data minimization (GDPR Art. 5(1)(c)) and purpose limitation (Art. 5(1)(b))
--   require that data collected for civil registration is not automatically
--   available to the passport authority, and vice versa. Even though both
--   authorities need some of the same data (name, date of birth, nationality),
--   they receive it independently from the data subject — not from each other.
--   This models the correct legal relationship: the passport authority is not
--   a downstream consumer of the civil registry's database; it independently
--   verifies identity and issues its own credential. Cross-authority data
--   sharing, where it exists, must be explicitly authorized and subject to
--   its own legal basis.
--
-- FAILURE MODE:
--   In a monolithic identity system, birth registry data would be directly
--   queried by the passport authority — creating an implicit data-sharing
--   arrangement with no GDPR legal basis. If the civil registry were an
--   observer on DigitalPassport contracts, it would receive every passport
--   update, including name changes and photo updates, without the holder's
--   knowledge. The module-isolated design prevents this by construction.
testBirthCertToPassport : Script ()
testBirthCertToPassport = do
  civilRegistry <- allocatePartyByHint (PartyIdHint "civil-registry")
  usAuthority <- allocatePartyByHint (PartyIdHint "us-authority")
  alice <- allocatePartyByHint (PartyIdHint "alice")

  -- Setup authorities
  submit civilRegistry do
    createCmd CivilRegistryAuthority with
      authority = civilRegistry
      jurisdiction = "US"

  submit usAuthority do
    createCmd IssuingAuthority with
      authority = usAuthority
      country = "US"

  -- Step 1: Register birth
  let birthInfo = BirthInfo with
        fullName = "Alice Johnson"
        dateOfBirth = date 1990 Jan 15
        placeOfBirth = "New York, USA"
        sex = Female
        motherName = "Mary Johnson"
        fatherName = "John Johnson"
        registrationNumber = "BC-2024-001"

  birthReqCid <- submit alice do
    createCmd BirthRegistrationRequest with
      requester = alice
      registry = civilRegistry
      birthInfo

  birthCertCid <- submit civilRegistry do
    exerciseCmd birthReqCid BC.Approve

  -- Verify birth certificate
  birthCert <- queryContractId alice birthCertCid
  case birthCert of
    None -> abort "Birth certificate should exist"
    Some bc -> assertMsg "Birth cert name should match" (bc.birthInfo.fullName == "Alice Johnson")

  -- Step 2: Use identity from birth cert to request passport
  let passportInfo = PassportInfo with
        fullName = birthInfo.fullName
        dateOfBirth = birthInfo.dateOfBirth
        nationality = "US"
        passportNumber = "US123456789"
        photoHash = "sha256:alice_photo_abc123"
        issueDate = date 2023 Jun 1
        expiryDate = date 2033 Jun 1

  passportReqCid <- submit alice do
    createCmd IdentityRequest with
      holder = alice
      authority = usAuthority
      passportInfo

  passportCid <- submit usAuthority do
    exerciseCmd passportReqCid PP.Approve

  -- Verify passport exists with matching info
  passport <- queryContractId alice passportCid
  case passport of
    None -> abort "Passport should exist"
    Some p -> do
      assertMsg "Passport name should match birth cert" (p.passportInfo.fullName == "Alice Johnson")
      assertMsg "Passport DOB should match birth cert" (p.passportInfo.dateOfBirth == date 1990 Jan 15)

  pure ()

-- | Test 2: Identity → voter registration — cross-module identity portability
--
-- PRIVACY GUARANTEE:
--   Verifies that the passport authority does not become a stakeholder in the
--   electoral workflow. Alice uses her passport's identity fields to populate
--   a VoterRegistrationRequest, but the passport authority (usAuthority) is
--   not a party to the VoterRegistration, the Election, or the Ballot. The
--   election commission does not have access to Alice's passport contract.
--   Electoral participation and travel document issuance are fully isolated
--   stakeholder scopes — the holder carries data between them, not the
--   authorities.
--
-- REGULATORY SIGNIFICANCE:
--   The separation of electoral identity from government-issued travel
--   documents reflects a constitutional privacy principle in many democracies:
--   voter registration data and passport data are maintained by separate
--   agencies with separate legal mandates, and cross-linking them requires
--   explicit legislative authorization. Automatically connecting them through
--   shared observer access would create a political profile — who is registered
--   to vote, in which constituency — accessible to the passport authority,
--   which has no lawful basis under GDPR Article 9(2) to process electoral
--   participation data. The integration test verifies that this cross-linking
--   does not occur at the ledger level.
--
-- FAILURE MODE:
--   If the passport authority were an observer on VoterRegistration contracts
--   — for example, through a design that added all prior identity attestors
--   as observers on derived identity credentials — the government would have
--   a real-time feed of electoral enrollment activity across all passport
--   holders. In jurisdictions with restricted political freedoms, this would
--   constitute a surveillance infrastructure enabling political targeting.
testIdentityToVoterRegistration : Script ()
testIdentityToVoterRegistration = do
  usAuthority <- allocatePartyByHint (PartyIdHint "us-authority")
  commission <- allocatePartyByHint (PartyIdHint "election-commission")
  alice <- allocatePartyByHint (PartyIdHint "alice")

  -- Setup authorities
  submit usAuthority do
    createCmd IssuingAuthority with
      authority = usAuthority
      country = "US"

  submit commission do
    createCmd ElectionCommission with
      authority = commission
      jurisdiction = "US"

  -- Step 1: Get passport (establishes identity)
  let passportInfo = PassportInfo with
        fullName = "Alice Johnson"
        dateOfBirth = date 1990 Jan 15
        nationality = "US"
        passportNumber = "US123456789"
        photoHash = "sha256:alice_photo_abc123"
        issueDate = date 2023 Jun 1
        expiryDate = date 2033 Jun 1

  passportReqCid <- submit alice do
    createCmd IdentityRequest with
      holder = alice
      authority = usAuthority
      passportInfo

  submit usAuthority do
    exerciseCmd passportReqCid PP.Approve

  -- Step 2: Register to vote using identity info from passport
  let personalInfo = PersonalInfo with
        fullName = passportInfo.fullName
        dateOfBirth = passportInfo.dateOfBirth
        nationality = passportInfo.nationality

  voterRegReqCid <- submit alice do
    createCmd VoterRegistrationRequest with
      voter = alice
      commission
      voterInfo = VoterInfo with
        personalInfo
        constituency = "District 1"
        voterIdNumber = "V-001"

  voterRegCid <- submit commission do
    exerciseCmd voterRegReqCid V.ApproveRegistration

  -- Verify voter registration exists via CID
  voterRegLookup <- queryContractId commission voterRegCid
  assertMsg "Voter registration should exist" (isSome voterRegLookup)

  -- Step 3: Create and participate in election
  electionCid <- submit commission do
    createCmd Election with
      commission
      electionId = "2024-GENERAL"
      description = "2024 General Election"
      candidates = ["Candidate A", "Candidate B"]
      status = Open
      voters = []

  (_, ballotCid) <- submit (actAs alice <> readAs commission) do
    exerciseCmd electionCid CastBallot with
      voter = alice
      voterRegCid = voterRegCid
      choice_ = "Candidate A"

  -- Verify ballot was cast via CID
  ballotLookup <- queryContractId alice ballotCid
  assertMsg "Ballot should exist" (isSome ballotLookup)

  pure ()

-- | Test 3: Identity → KYC — identity-to-financial-compliance chain
--
-- PRIVACY GUARANTEE:
--   Verifies that the KYC clearance for Alice at a financial institution does
--   not grant the institution access to Alice's passport or birth certificate.
--   The institution (bankKYC) receives only what Alice provides in her
--   KYCData submission — she copies name, date of birth, and nationality from
--   her passport fields, but the bank has no ContractId reference to the
--   passport and is not a stakeholder on it. The KYCClearance is co-signed by
--   institution and customer; the passport authority is absent from that
--   contract entirely.
--
-- REGULATORY SIGNIFICANCE:
--   BSA CIP rules (31 CFR § 1020.220) require the institution to collect and
--   verify identity information — they do not grant the institution access to
--   the government's identity database. The institution must independently
--   verify the information provided, using documentary evidence (a copy of the
--   passport, in practice). The DAML model reflects this correctly: the
--   institution receives customer-provided data and makes its own verification
--   determination. If the institution were an observer on DigitalPassport, it
--   would have live access to the government's identity record — a data-sharing
--   arrangement that would require a formal government-to-institution data
--   sharing agreement and explicit GDPR legal basis under Article 6(1)(e) or (c).
--   The current design avoids this by keeping the institution's KYC data
--   entirely within the AML module's stakeholder scope.
--
-- FAILURE MODE:
--   If financial institutions were granted observer access on passport contracts
--   as a convenience for KYC verification, the government identity database
--   would become effectively public to the regulated financial sector. Every
--   passport update — name change, renewal, revocation — would be broadcast to
--   every bank that had ever performed KYC on the holder. This would constitute
--   unauthorized processing of special-category biometric data (GDPR Art. 9)
--   by private institutions without a valid legal basis.
testIdentityToKYC : Script ()
testIdentityToKYC = do
  usAuthority <- allocatePartyByHint (PartyIdHint "us-authority")
  bankKYC <- allocatePartyByHint (PartyIdHint "bank-kyc")
  alice <- allocatePartyByHint (PartyIdHint "alice")

  -- Setup authority
  submit usAuthority do
    createCmd IssuingAuthority with
      authority = usAuthority
      country = "US"

  -- Step 1: Get passport
  let passportInfo = PassportInfo with
        fullName = "Alice Johnson"
        dateOfBirth = date 1990 Jan 15
        nationality = "US"
        passportNumber = "US123456789"
        photoHash = "sha256:alice_photo_abc123"
        issueDate = date 2023 Jun 1
        expiryDate = date 2033 Jun 1

  passportReqCid <- submit alice do
    createCmd IdentityRequest with
      holder = alice
      authority = usAuthority
      passportInfo

  submit usAuthority do
    exerciseCmd passportReqCid PP.Approve

  -- Step 2: Bank requests KYC
  kycReqCid <- submit bankKYC do
    createCmd KYCRequest with
      institution = bankKYC
      customer = alice
      purpose = "Account opening"

  -- Step 3: Alice provides KYC data derived from passport info
  let kycData = KYCData with
        personalInfo = PersonalInfo with
          fullName = passportInfo.fullName
          dateOfBirth = passportInfo.dateOfBirth
          nationality = passportInfo.nationality
        address = "123 Main St, New York, NY"
        taxId = "SSN-123-45-6789"
        sourceOfFunds = "Employment"
        occupation = "Software Engineer"

  submissionCid <- submit alice do
    exerciseCmd kycReqCid ProvideKYC with
      kycData

  -- Step 4: Bank clears KYC
  clearanceCid <- submit bankKYC do
    exerciseCmd submissionCid ApproveKYC with
      riskLevel = Low

  -- Verify clearance via CID
  clearanceLookup <- queryContractId bankKYC clearanceCid
  assertMsg "KYC clearance should exist" (isSome clearanceLookup)

  clearance <- queryContractId alice clearanceCid
  case clearance of
    None -> abort "KYC clearance should exist"
    Some c -> do
      assertMsg "Name in KYC should match passport" (c.kycData.personalInfo.fullName == "Alice Johnson")
      assertMsg "Risk level should be Low" (c.riskLevel == Low)

  pure ()

-- | Setup script for sandbox.
-- Pre-populates the ledger with authorities, passports, birth cert,
-- voter registration, and an open election so you can explore immediately.
setup : Script ()
setup = do
  -- Allocate all parties
  usAuthority <- allocatePartyByHint (PartyIdHint "us-authority")
  jpAuthority <- allocatePartyByHint (PartyIdHint "jp-authority")
  civilRegistry <- allocatePartyByHint (PartyIdHint "civil-registry")
  commission <- allocatePartyByHint (PartyIdHint "election-commission")
  regulator <- allocatePartyByHint (PartyIdHint "financial-regulator")
  contentReg <- allocatePartyByHint (PartyIdHint "content-registry")
  alice <- allocatePartyByHint (PartyIdHint "alice")
  bob <- allocatePartyByHint (PartyIdHint "bob")
  _airportCheck <- allocatePartyByHint (PartyIdHint "airport-check")
  bankKYC <- allocatePartyByHint (PartyIdHint "bank-kyc")

  -- Register all authorities
  submit usAuthority do
    createCmd IssuingAuthority with authority = usAuthority, country = "US"
  submit jpAuthority do
    createCmd IssuingAuthority with authority = jpAuthority, country = "JP"
  submit civilRegistry do
    createCmd CivilRegistryAuthority with authority = civilRegistry, jurisdiction = "US"
  submit commission do
    createCmd ElectionCommission with authority = commission, jurisdiction = "US"
  submit regulator do
    createCmd FinancialRegulator with authority = regulator, jurisdiction = "US"
  submit contentReg do
    createCmd ContentRegistry with authority = contentReg, domain = "Global"

  -- Alice: birth certificate
  let aliceBirthInfo = BirthInfo with
        fullName = "Alice Johnson"
        dateOfBirth = date 1990 Jan 15
        placeOfBirth = "New York, USA"
        sex = Female
        motherName = "Mary Johnson"
        fatherName = "John Johnson"
        registrationNumber = "BC-2024-001"
  birthReqCid <- submit alice do
    createCmd BirthRegistrationRequest with
      requester = alice, registry = civilRegistry, birthInfo = aliceBirthInfo
  submit civilRegistry do
    exerciseCmd birthReqCid BC.Approve

  -- Alice: US passport
  let alicePassportInfo = PassportInfo with
        fullName = "Alice Johnson"
        dateOfBirth = date 1990 Jan 15
        nationality = "US"
        passportNumber = "US123456789"
        photoHash = "sha256:alice_photo_abc123"
        issueDate = date 2023 Jun 1
        expiryDate = date 2033 Jun 1
  alicePassReqCid <- submit alice do
    createCmd IdentityRequest with
      holder = alice, authority = usAuthority, passportInfo = alicePassportInfo
  submit usAuthority do
    exerciseCmd alicePassReqCid PP.Approve

  -- Bob: JP passport
  let bobPassportInfo = PassportInfo with
        fullName = "Bob Tanaka"
        dateOfBirth = date 1985 Mar 20
        nationality = "JP"
        passportNumber = "JP987654321"
        photoHash = "sha256:bob_photo_def456"
        issueDate = date 2022 Sep 15
        expiryDate = date 2032 Sep 15
  bobPassReqCid <- submit bob do
    createCmd IdentityRequest with
      holder = bob, authority = jpAuthority, passportInfo = bobPassportInfo
  submit jpAuthority do
    exerciseCmd bobPassReqCid PP.Approve

  -- Alice: voter registration
  voterRegReqCid <- submit alice do
    createCmd VoterRegistrationRequest with
      voter = alice
      commission
      voterInfo = VoterInfo with
        personalInfo = PersonalInfo with
          fullName = "Alice Johnson"
          dateOfBirth = date 1990 Jan 15
          nationality = "US"
        constituency = "District 1"
        voterIdNumber = "V-001"
  submit commission do
    exerciseCmd voterRegReqCid V.ApproveRegistration

  -- Open election ready for voting
  submit commission do
    createCmd Election with
      commission
      electionId = "2024-GENERAL"
      description = "2024 General Election"
      candidates = ["Candidate A", "Candidate B", "Candidate C"]
      status = Open
      voters = []

  -- KYC request waiting for Alice to respond
  submit bankKYC do
    createCmd KYCRequest with
      institution = bankKYC
      customer = alice
      purpose = "Account opening"

  -- Alice: content certificate
  let contentInfo = ContentInfo with
        title = "Alice's Digital Artwork"
        contentHash = "sha256:artwork_hash_001"
        contentType = Image
        creator = alice
        creationDate = date 2024 Jan 1
        description = "Original digital painting"
  contentReqCid <- submit alice do
    createCmd ContentRegistrationRequest with
      creator = alice, registry = contentReg, contentInfo
  submit contentReg do
    exerciseCmd contentReqCid CC.ApproveRegistration

  pure ()
